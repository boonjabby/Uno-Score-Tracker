{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null && ((!data.exists() && newData.child('hostUid').val() === auth.uid) || data.child('hostUid').val() === auth.uid)",
        "hostUid": { ".validate": "newData.isString() && newData.val() === auth.uid" },
        "code": { ".validate": "newData.isString() && newData.val().matches(/^[A-HJ-NP-Z2-9]{6}$/)" },
        "game": { ".validate": "newData.hasChildren(['gameType','participantCount','targetScore','clockwise','names','scores'])" }
      }
    },
    "roomCodes": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && ((!data.exists() && newData.child('hostUid').val() === auth.uid) || data.child('hostUid').val() === auth.uid)",
        "roomId": { ".validate": "newData.isString() && newData.val().matches(/^[a-f0-9]{32}$/)" },
        "hostUid": { ".validate": "newData.isString() && newData.val() === auth.uid" }
      }
    }
  }
}
